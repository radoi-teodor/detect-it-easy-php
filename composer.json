{
    "name": "edimemune/detect-it-easy-php",
    "description": "A powerful file type detection and analysis library for cybersecurity experts and reverse engineers. Identifies executables, archives, packers, compilers, protectors, and more.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "file-detection",
        "malware-analysis",
        "reverse-engineering",
        "packer-detection",
        "binary-analysis",
        "forensics",
        "PE",
        "ELF",
        "Mach-O",
        "APK"
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "DetectItEasy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DetectItEasy\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
